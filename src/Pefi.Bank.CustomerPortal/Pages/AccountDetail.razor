@page "/accounts/{Id:guid}"
@inject BankApiClient Api
@inject CustomerState State
@implements IDisposable

@if (!State.IsLoggedIn)
{
    <div class="page-header">
        <h1 class="page-title">Account Details</h1>
    </div>
    <div class="card" style="max-width: 400px;">
        <div class="empty-state">
            <div class="empty-state-title">Not signed in</div>
            <div class="empty-state-text">Please <a href="/signin">sign in</a> to view account details.</div>
        </div>
    </div>
}
else if (account == null)
{
    <div class="loading-card">
        <div class="spinner"></div>
        <span>Loading account...</span>
    </div>
}
else
{
    <a href="accounts" class="back-link">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
        </svg>
        Back to Accounts
    </a>

    @* --- Account Summary Card --- *@
    <div class="card mb-4" style="max-width: 560px;">
        <div class="account-card-header">
            <span class="account-card-name" style="font-size: 1.15rem;">@account.AccountName</span>
            <span class="account-card-badge @(account.IsClosed ? "badge-closed" : "badge-active")">
                @(account.IsClosed ? "Closed" : "Active")
            </span>
        </div>
        <div class="account-card-sort-acct mt-2">@account.SortCode &middot; @account.AccountNumber</div>
        <div class="balance-hero mt-2">@account.Balance.ToString("C")</div>
        <div class="text-muted mt-2" style="font-size: 0.8rem;">Opened @account.OpenedAt.ToString("dd MMMM yyyy")</div>

        @if (!account.IsClosed)
        {
            <div class="mt-3">
                <button type="button" class="btn btn-primary btn-sm" @onclick="OpenTransferModal">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="width: 16px; height: 16px; fill: white;">
                        <path d="M6.99 11L3 15l3.99 4v-3H14v-2H6.99v-3zM21 9l-3.99-4v3H10v2h7.01v3L21 9z"/>
                    </svg>
                    Transfer
                </button>
            </div>
        }
    </div>

    @* --- Pending Transfers --- *@
    @if (pendingTransfers != null && pendingTransfers.Count > 0)
    {
        <div class="card mb-4" style="max-width: 560px;">
            <div class="section-header">
                <h3 class="section-title">Pending Transfers</h3>
                <span class="pending-count">@pendingTransfers.Count</span>
            </div>

            <div class="pending-list">
                @foreach (var t in pendingTransfers)
                {
                    <div class="pending-item">
                        <div class="pending-icon">
                            <div class="spinner" style="width: 16px; height: 16px; border-width: 2px;"></div>
                        </div>
                        <div class="pending-details">
                            <div class="pending-description">
                                @GetTransferLabel(t)
                            </div>
                            <div class="pending-meta">
                                @t.Status &middot; @t.InitiatedAt.ToString("dd MMM, HH:mm")
                            </div>
                        </div>
                        <div class="pending-amount @GetPendingAmountClass(t)">
                            @GetPendingAmountPrefix(t)@t.Amount.ToString("C")
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* --- Transaction History --- *@
    <div class="card">
        <div class="section-header">
            <h3 class="section-title">Transaction History</h3>
        </div>

        @if (transactions == null)
        {
            <div class="loading-card">
                <div class="spinner"></div>
                <span>Loading transactions...</span>
            </div>
        }
        else if (transactions.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-title">No transactions yet</div>
                <div class="empty-state-text">Make a deposit or withdrawal to see your history here.</div>
            </div>
        }
        else
        {
            <div class="tx-list">
                @foreach (var tx in transactions)
                {
                    <div class="tx-item">
                        <div class="tx-icon @GetTxIconClass(tx.Type)">
                            @((MarkupString)GetTxIconSvg(tx.Type))
                        </div>
                        <div class="tx-details">
                            <div class="tx-type">@tx.Type</div>
                            <div class="tx-description">@(string.IsNullOrEmpty(tx.Description) ? "No description" : tx.Description)</div>
                            <div class="tx-date">@tx.OccurredAt.ToString("dd MMM yyyy, HH:mm")</div>
                        </div>
                        <div class="tx-amounts">
                            <div class="tx-amount @GetTxAmountClass(tx.Type)">
                                @GetTxAmountPrefix(tx.Type)@tx.Amount.ToString("C")
                            </div>
                            <div class="tx-balance-after">Bal: @tx.BalanceAfter.ToString("C")</div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* --- Transfer Modal --- *@
    @if (showTransferModal)
    {
        <div class="modal-backdrop" @onclick="CloseTransferModal"></div>
        <div class="modal">
            <div class="modal-header">
                <h3 class="modal-title">Transfer</h3>
                <button type="button" class="modal-close" @onclick="CloseTransferModal" disabled="@(transferInProgress && activeTransfer?.Status is not "Completed" and not "Failed")">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                </button>
            </div>

            @if (activeTransfer == null)
            {
                <div class="modal-body">
                    <div class="form-group">
                        <label class="form-label">From Account</label>
                        <select class="form-select" @bind="transferSourceId">
                            <option value="">Select source account</option>
                            @foreach (var acct in allAccounts!.Where(a => !a.IsClosed))
                            {
                                <option value="@acct.Id">@acct.AccountName &middot; @acct.AccountNumber (@acct.Balance.ToString("C"))</option>
                            }
                        </select>
                    </div>

                    <div class="transfer-arrow">
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z" transform="rotate(90 12 12)"/>
                        </svg>
                    </div>

                    <div class="form-group">
                        <label class="form-label">To Account</label>
                        <select class="form-select" @bind="transferDestId">
                            <option value="">Select destination account</option>
                            @foreach (var acct in allAccounts!.Where(a => !a.IsClosed))
                            {
                                <option value="@acct.Id">@acct.AccountName &middot; @acct.AccountNumber (@acct.Balance.ToString("C"))</option>
                            }
                        </select>
                    </div>

                    <div class="form-group mt-3">
                        <label class="form-label">Amount</label>
                        <input type="number" step="0.01" min="0.01" class="form-input" @bind="transferAmount" placeholder="0.00" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Description (optional)</label>
                        <input type="text" class="form-input" @bind="transferDescription" placeholder="What's this transfer for?" />
                    </div>

                    @if (!string.IsNullOrEmpty(transferError))
                    {
                        <div class="alert alert-error">@transferError</div>
                    }
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline" @onclick="CloseTransferModal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SubmitTransfer" disabled="@transferInProgress">
                        @(transferInProgress ? "Submitting..." : "Transfer")
                    </button>
                </div>
            }
            else
            {
                <div class="modal-body">
                    <div class="transfer-status-summary mb-3">
                        <div class="text-secondary" style="font-size: 0.85rem;">
                            @GetAccountName(activeTransfer.SourceAccountId) &rarr; @GetAccountName(activeTransfer.DestinationAccountId)
                        </div>
                        <div class="balance-medium mt-1">@activeTransfer.Amount.ToString("C")</div>
                        @if (!string.IsNullOrEmpty(activeTransfer.Description))
                        {
                            <div class="text-muted mt-1" style="font-size: 0.85rem;">@activeTransfer.Description</div>
                        }
                    </div>

                    <div class="transfer-steps">
                        <div class="transfer-step @StepClass("Initiated")">
                            <div class="transfer-step-indicator">@StepIcon("Initiated")</div>
                            <div class="transfer-step-label">Transfer initiated</div>
                        </div>
                        <div class="transfer-step @StepClass("SourceDebited")">
                            <div class="transfer-step-indicator">@StepIcon("SourceDebited")</div>
                            <div class="transfer-step-label">Source account debited</div>
                        </div>
                        <div class="transfer-step @StepClass("DestinationCredited")">
                            <div class="transfer-step-indicator">@StepIcon("DestinationCredited")</div>
                            <div class="transfer-step-label">Destination account credited</div>
                        </div>
                        <div class="transfer-step @StepClass("Completed")">
                            <div class="transfer-step-indicator">@StepIcon("Completed")</div>
                            <div class="transfer-step-label">Transfer complete</div>
                        </div>
                    </div>

                    @if (activeTransfer.Status == "Failed")
                    {
                        <div class="alert alert-error mt-3">
                            Transfer failed@(activeTransfer.FailureReason != null ? $": {activeTransfer.FailureReason}" : "")
                        </div>
                    }
                </div>

                @if (activeTransfer.Status is "Completed" or "Failed")
                {
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline" @onclick="CloseTransferModal">Close</button>
                    </div>
                }
            }
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    // Page data
    private AccountReadModel? account;
    private List<AccountReadModel>? allAccounts;
    private List<StatementEntryReadModel>? transactions;
    private List<TransferReadModel>? pendingTransfers;

    // Transfer modal state
    private bool showTransferModal;
    private string transferSourceId = string.Empty;
    private string transferDestId = string.Empty;
    private decimal transferAmount;
    private string transferDescription = string.Empty;
    private string? transferError;
    private bool transferInProgress;
    private TransferReadModel? activeTransfer;
    private CancellationTokenSource? sseCts;

    private static readonly Guid SettlementAccountId = Guid.Parse("00000000-0000-0000-0000-000000000001");
    private static readonly string[] StatusOrder = ["Initiated", "SourceDebited", "DestinationCredited", "Completed"];

    protected override async Task OnInitializedAsync()
    {
        if (State.IsLoggedIn)
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        var accountsTask = Api.GetAccountsAsync(State.CustomerId!.Value);
        var transactionsTask = Api.GetStatementEntriesAsync(Id);
        var transfersTask = Api.GetTransfersForAccountAsync(Id);

        await Task.WhenAll(accountsTask, transactionsTask, transfersTask);

        allAccounts = await accountsTask;
        account = allAccounts.FirstOrDefault(a => a.Id == Id);
        transactions = await transactionsTask;

        var allTransfers = await transfersTask;
        pendingTransfers = allTransfers
            .Where(t => t.Status is not "Completed" and not "Failed")
            .OrderByDescending(t => t.InitiatedAt)
            .ToList();
    }

    // --- Transfer modal ---

    private void OpenTransferModal()
    {
        transferSourceId = Id.ToString();
        transferDestId = string.Empty;
        transferAmount = 0;
        transferDescription = string.Empty;
        transferError = null;
        transferInProgress = false;
        activeTransfer = null;
        showTransferModal = true;
    }

    private void CloseTransferModal()
    {
        if (transferInProgress && activeTransfer?.Status is not "Completed" and not "Failed")
            return; // don't close while transfer is in flight

        showTransferModal = false;
        sseCts?.Cancel();
        sseCts?.Dispose();
        sseCts = null;

        // Refresh page data if a transfer completed
        if (activeTransfer?.Status is "Completed" or "Failed")
        {
            _ = LoadData().ContinueWith(_ => InvokeAsync(StateHasChanged));
        }

        activeTransfer = null;
    }

    private async Task SubmitTransfer()
    {
        transferError = null;

        if (string.IsNullOrEmpty(transferSourceId) || string.IsNullOrEmpty(transferDestId))
        {
            transferError = "Please select both source and destination accounts.";
            return;
        }

        if (transferSourceId == transferDestId)
        {
            transferError = "Source and destination must be different accounts.";
            return;
        }

        if (transferAmount <= 0)
        {
            transferError = "Amount must be greater than zero.";
            return;
        }

        transferInProgress = true;
        try
        {
            var command = new TransferCommand(
                Guid.Parse(transferSourceId),
                Guid.Parse(transferDestId),
                transferAmount,
                transferDescription);

            var response = await Api.TransferAsync(command);

            activeTransfer = new TransferReadModel(
                Id: response.Id,
                SourceAccountId: Guid.Parse(transferSourceId),
                DestinationAccountId: Guid.Parse(transferDestId),
                Amount: transferAmount,
                Description: transferDescription,
                Status: response.Status,
                FailureReason: null,
                InitiatedAt: DateTime.UtcNow,
                UpdatedAt: DateTime.UtcNow,
                CompletedAt: null);

            StateHasChanged();

            await SubscribeToTransferEvents(response.EventsUrl, response.Id);
        }
        catch (Exception ex)
        {
            transferError = $"Transfer failed: {ex.Message}";
            transferInProgress = false;
        }
    }

    private async Task SubscribeToTransferEvents(string eventsUrl, Guid transferId)
    {
        sseCts = new CancellationTokenSource(TimeSpan.FromSeconds(3000));
        try
        {
            await foreach (var data in Api.SubscribeToTransferEventsAsync(eventsUrl, sseCts.Token))
            {
                var updated = await Api.GetTransferAsync(transferId);
                if (updated != null)
                {
                    activeTransfer = updated;
                    await InvokeAsync(StateHasChanged);
                }

                if (activeTransfer?.Status is "Completed" or "Failed")
                {
                    transferInProgress = false;
                    await LoadData();
                    await InvokeAsync(StateHasChanged);
                    break;
                }
            }
        }
        catch (OperationCanceledException)
        {
            var updated = await Api.GetTransferAsync(transferId);
            if (updated != null)
                activeTransfer = updated;
            transferInProgress = false;
            await LoadData();
            await InvokeAsync(StateHasChanged);
        }
    }

    // --- Helpers ---

    private string GetAccountName(Guid accountId)
    {
        return allAccounts?.FirstOrDefault(a => a.Id == accountId)?.AccountName ?? "Account";
    }

    private string GetTransferLabel(TransferReadModel t)
    {
        if (t.SourceAccountId == SettlementAccountId)
            return $"Deposit: {t.Description}";
        if (t.DestinationAccountId == SettlementAccountId)
            return $"Withdrawal: {t.Description}";

        var direction = t.SourceAccountId == Id ? "Transfer out" : "Transfer in";
        return string.IsNullOrEmpty(t.Description) ? direction : $"{direction}: {t.Description}";
    }

    private string GetPendingAmountClass(TransferReadModel t)
    {
        if (t.SourceAccountId == SettlementAccountId) return "tx-amount-positive";
        if (t.DestinationAccountId == SettlementAccountId) return "tx-amount-negative";
        return t.SourceAccountId == Id ? "tx-amount-negative" : "tx-amount-positive";
    }

    private string GetPendingAmountPrefix(TransferReadModel t)
    {
        if (t.SourceAccountId == SettlementAccountId) return "+";
        if (t.DestinationAccountId == SettlementAccountId) return "-";
        return t.SourceAccountId == Id ? "-" : "+";
    }

    private int StatusIndex(string status) =>
        Array.IndexOf(StatusOrder, status);

    private string StepClass(string step)
    {
        if (activeTransfer?.Status == "Failed")
        {
            var failedAtIndex = StatusIndex(activeTransfer.Status);
            var stepIndex = StatusIndex(step);
            return stepIndex < failedAtIndex ? "step-done" : "step-failed";
        }

        var currentIndex = StatusIndex(activeTransfer?.Status ?? "");
        var thisStepIndex = StatusIndex(step);

        if (activeTransfer?.Status == "Completed") return "step-done";
        if (thisStepIndex < currentIndex) return "step-done";
        if (thisStepIndex == currentIndex) return "step-active";
        return "step-pending";
    }

    private string StepIcon(string step)
    {
        var cls = StepClass(step);
        return cls switch
        {
            "step-done" => "\u2713",
            "step-active" => "\u25CF",
            "step-failed" => "\u2717",
            _ => "\u25CB"
        };
    }

    private static string GetTxIconClass(StatementEntryType type) => type switch
    {
        StatementEntryType.Credit => "tx-icon-deposit",
        StatementEntryType.Debit => "tx-icon-withdrawal",
        _ => "tx-icon-transfer"
    };

    private static string GetTxIconSvg(StatementEntryType type) => type switch
    {
        StatementEntryType.Credit => """<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>""",
        StatementEntryType.Debit => """<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 4l1.41 1.41L7.83 11H20v2H7.83l5.58 5.59L12 20l-8-8z"/></svg>""",
        _ => """<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M6.99 11L3 15l3.99 4v-3H14v-2H6.99v-3zM21 9l-3.99-4v3H10v2h7.01v3L21 9z"/></svg>"""
    };

    private static string GetTxAmountClass(StatementEntryType type) => type switch
    {
        StatementEntryType.Credit => "tx-amount-positive",
        StatementEntryType.Debit => "tx-amount-negative",
        _ => "tx-amount-neutral"
    };

    private static string GetTxAmountPrefix(StatementEntryType type) => type switch
    {
        StatementEntryType.Credit => "+",
        StatementEntryType.Debit => "-",
        _ => ""
    };

    public void Dispose()
    {
        sseCts?.Cancel();
        sseCts?.Dispose();
    }
}
